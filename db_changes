--
-- Table structure for table `specifications`
--
DROP TABLE IF EXISTS `specifications`;
CREATE TABLE `specifications` (
  `id` bigint(20) UNSIGNED NOT NULL AUTO_INCREMENT,
  `main_title` varchar(191) NOT NULL,
  `display_title` varchar(191) DEFAULT NULL,
  `status` tinyint(1) NOT NULL DEFAULT 1,
  `created_by` bigint(20) UNSIGNED DEFAULT NULL,
  `updated_by` bigint(20) UNSIGNED DEFAULT NULL,
  `created_at` timestamp NULL,
  `updated_at` timestamp NULL,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

--
-- Table structure for table `specification_items`
--
DROP TABLE IF EXISTS `specification_items`;
CREATE TABLE `specification_items` (
  `id` bigint(20) UNSIGNED NOT NULL AUTO_INCREMENT,
  `main_specification_id` bigint(20) UNSIGNED NOT NULL,
  `parent_id` bigint(20) UNSIGNED NOT NULL DEFAULT 0,
  `title` varchar(191) NOT NULL,
  `display_title` varchar(191) DEFAULT NULL,
  `status` tinyint(1) NOT NULL DEFAULT 1,
  `sort_order` int(11) DEFAULT 0,
  `created_at` timestamp NULL,
  `updated_at` timestamp NULL,
  PRIMARY KEY (`id`),
  KEY `specification_items_main_specification_id_foreign` (`main_specification_id`),
  CONSTRAINT `specification_items_main_specification_id_foreign`
    FOREIGN KEY (`main_specification_id`)
    REFERENCES `specifications` (`id`)
    ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

